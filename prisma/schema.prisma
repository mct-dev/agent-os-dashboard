generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3b82f6")
  emoji     String   @default("📦")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
  comments  Comment[]
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status      Status      @default(BACKLOG)
  priority    Priority    @default(MEDIUM)
  sopId       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  runs        AgentRun[]
  inboxItems  InboxItem[]
  comments    Comment[]
}

model AgentRun {
  id               String      @id @default(cuid())
  taskId           String?
  task             Task?       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  bridgeRunId      String?
  status           RunStatus   @default(PENDING)
  model            String      @default("anthropic/claude-opus-4-6")
  prompt           String?
  costUsd          Float?
  tokenCount       Int?
  output           String?
  startedAt        DateTime    @default(now())
  endedAt          DateTime?
  triggerCommentId String?
  triggerComment   Comment?    @relation("TriggeredByComment", fields: [triggerCommentId], references: [id], onDelete: SetNull)
  agentConfigId    String?
  inboxItems       InboxItem[]
  comments         Comment[]   @relation("RunComments")
}

model Sop {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  stages      SopStage[]
  agents      AgentConfig[]
}

model SopStage {
  id        String @id @default(cuid())
  sopId     String
  sop       Sop    @relation(fields: [sopId], references: [id], onDelete: Cascade)
  name      String
  role      String
  prompt    String
  sortOrder Int    @default(0)

  @@index([sopId])
}

model AgentConfig {
  id           String   @id @default(cuid())
  name         String   @unique
  tool         String   @default("claude-code")
  model        String   @default("claude-sonnet-4-6")
  description  String   @default("")
  systemPrompt String   @default("")
  defaultSopId String?
  defaultSop   Sop?     @relation(fields: [defaultSopId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InboxItem {
  id           String    @id @default(cuid())
  agentRunId   String?
  agentRun     AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  taskId       String?
  task         Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentName    String
  taskTitle    String    @default("")
  question     String
  priority     Priority  @default(MEDIUM)
  read         Boolean   @default(false)
  snoozedUntil DateTime?
  repliedAt    DateTime?
  replyText    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([taskId])
  @@index([read])
  @@index([agentRunId])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  bridgeUrl          String?
  bridgeApiKey       String?
  bridgeName         String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Comment {
  id          String    @id @default(cuid())
  body        String

  taskId      String?
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentRunId  String?
  agentRun    AgentRun? @relation("RunComments", fields: [agentRunId], references: [id], onDelete: Cascade)

  userId      String?
  agentId     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  triggeredRuns AgentRun[] @relation("TriggeredByComment")

  @@index([taskId])
  @@index([projectId])
  @@index([agentRunId])
}

enum Status {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  STOPPED
}
