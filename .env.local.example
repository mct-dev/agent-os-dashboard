DATABASE_URL="postgresql://..."
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ICARUS_API_KEY="generate-a-key"

# Vercel sets VERCEL_ENV and VERCEL_PROJECT_PRODUCTION_URL automatically.
# On preview deployments, OAuth callbacks are proxied through the production URL
# so only one Google redirect URI is needed. Both production and preview must
# share the same NEXTAUTH_SECRET for this to work.
